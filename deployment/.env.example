# Local deploy secrets — copy to .env and fill in.
# .env is gitignored. Never commit it.
#
# DEPLOYER_IP_ADDRESSES
#   Comma-separated list of public IPs or CIDR ranges that
#   should be allowlisted on Key Vault and WebJobs Storage
#   during an operator-driven deployment.
#
#   The deploy.ps1 script reads this value, compares it to
#   the operator's current public IP (via ipinfo.io), and
#   passes it to ARM via a CLI parameter override — so the
#   IP never lands in services-parameters-*.arm.json.
#
#   Example:
#     DEPLOYER_IP_ADDRESSES=203.0.113.42/32
#     DEPLOYER_IP_ADDRESSES=203.0.113.42/32,198.51.100.0/24
DEPLOYER_IP_ADDRESSES=
