# Local deploy secrets — copy to .env and fill in.
# .env is gitignored. Never commit it.
#
# DEPLOYER_IP_ADDRESSES
#   Comma-separated list of public IPs or CIDR ranges that
#   should be allowlisted on Key Vault and WebJobs Storage
#   during an operator-driven deployment.
#
#   The deploy.ps1 script reads this value, compares it to
#   the operator's current public IP (via ipinfo.io), and
#   passes it to ARM via a CLI parameter override — so the
#   IP never lands in services-parameters-*.arm.json.
#
#   Example:
#     DEPLOYER_IP_ADDRESSES=203.0.113.42/32
#     DEPLOYER_IP_ADDRESSES=203.0.113.42/32,198.51.100.0/24
DEPLOYER_IP_ADDRESSES=

# ADMIN_USERS_PRD / ADMIN_USERS_TEST
#   Comma-separated list of AAD object IDs (oids) that should
#   be treated as admins in each environment. Compared against
#   the token's `oid` claim by AdminGroupFilter — required to
#   call /api/v2/admops/* endpoints (e.g. run_dbmigration).
#
#   The deploy.ps1 script reads the variable matching the
#   selected -Environment and passes it to ARM as an override
#   for settings-adminConfiguration-adminUsers, so the oids
#   never land in services-parameters-*.arm.json.
#
#   Note: AAD mints a different oid per tenant for the same
#   human, so the prd value (issuer = MSA consumers tenant)
#   and the test value (issuer = home tenant) will differ.
#
#   If a variable is empty/absent, the template's placeholder
#   default is used and no human can invoke admin endpoints
#   in that environment.
#
#   Example:
#     ADMIN_USERS_PRD=00000000-0000-0000-1234-abcdefabcdef
#     ADMIN_USERS_TEST=11111111-2222-3333-4444-555555555555,00000000-0000-0000-1234-abcdefabcdef
ADMIN_USERS_PRD=
ADMIN_USERS_TEST=
